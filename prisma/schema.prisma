generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExpenseType {
  pessoal
  empresa
  cliente
}

enum ExpenseStatus {
  processado
  rever
}

enum CategoryScope {
  pessoal
  empresa
  cliente
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categories Category[]
  clients    Client[]
  expenses   Expense[]
}

model Category {
  id     String        @id @default(cuid())
  userId String?
  user   User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope  CategoryScope
  name   String

  @@unique([userId, scope, name])
  @@index([userId])
}

model Client {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String

  @@unique([userId, name])
  @@index([userId])
}

model Expense {
  code            String        @id
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant        String
  amount          Decimal       @db.Decimal(12, 2)
  currency        String
  date            DateTime      @db.Date
  type            ExpenseType
  category        String
  clientName      String?
  status          ExpenseStatus
  receiptImageUrl String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
}
